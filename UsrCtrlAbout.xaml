<UserControl x:Class="Click2Key.UsrCtrlAbout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#09090B">

    <UserControl.Resources>
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#18181B"/>
            <Setter Property="Foreground" Value="#F4F4F5"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="BorderBrush" Value="#27272A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#27272A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
        <!-- 👻 LARGER GHOST ICON -->
        <Grid Width="150" Height="150" Margin="0,0,0,25">
            <Ellipse Width="150" Height="150" Fill="#18181B"/>
            <TextBlock Text="👻" FontSize="64" FontWeight="Bold" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <!-- Developer Info – scaled up -->
        <TextBlock Text="Ali Al-ojeely" Foreground="White" FontSize="30" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <TextBlock Text="Junior Software Developer" Foreground="#A1A1AA" FontSize="18"
                   Margin="0,0,0,8" HorizontalAlignment="Center"/>

        <!-- Links – wider buttons, bigger text, more spacing -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
            <Button Content="GitHub Profile" Style="{StaticResource ModernButtonStyle}"
                    Width="260" Margin="0,0,0,12" Click="GitHub_Click"/>
            <Button Content="Portfolio Website" Style="{StaticResource ModernButtonStyle}"
                    Width="260" Margin="0,0,0,12" Click="Portfolio_Click"/>
            <Button Content="Contact Email" Style="{StaticResource ModernButtonStyle}"
                    Width="260" Margin="0,0,0,12" Click="Email_Click"/>
        </StackPanel>

        <!-- Version -->
        <TextBlock Text="Version 1.7" Foreground="#71717A" FontSize="16"
                   HorizontalAlignment="Center" Margin="0,0,0,30"/>
    </StackPanel>
</UserControl>